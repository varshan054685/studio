
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Additional information about a registered user.",
      "type": "object",
      "properties": {
        "displayName": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "photoURL": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "email"
      ]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A financial transaction recorded by the user.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string"
        },
        "date": {
          "type": "string",
          "format": "date"
        },
        "description": {
          "type": "string"
        },
        "amount": {
          "type": "number"
        },
        "category": {
          "type": "string"
        }
      },
      "required": [
        "userId",
        "date",
        "description",
        "amount",
        "category"
      ]
    }
  },
  "auth": {
    "providers": [
      "google.com",
      "password"
    ]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile data."
    },
    "/users/{userId}/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "User's financial transactions."
    }
  }
}
