rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isSafeProfileImage(fileName) {
      return request.resource != null
        && request.resource.size > 0
        && request.resource.size <= 2 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|png|webp|gif)')
        && fileName.matches('^avatar-[A-Za-z0-9._-]+\\.(jpg|jpeg|png|webp|gif)$');
    }

    match /users/{userId}/profile/{fileName} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) && isSafeProfileImage(fileName);
      allow delete: if isOwner(userId);
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
